# Copy this file to .dev.vars and fill in your values
# .dev.vars is gitignored and contains secrets for local development

# Shared secret for exec server authentication
# Generate with: openssl rand -hex 32
EXEC_SECRET=your-secret-here

# Optional: Override exec server URL (defaults to http://127.0.0.1:9898)
# EXEC_SERVER_URL=http://127.0.0.1:9898
