{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$comment": "Example secret structure for resist.js projects. Copy and customize for your product.",

	"global": {
		"$comment": "Shared across all products - stored in 'global' Infisical project",
		"CLOUDFLARE_API_TOKEN": "your-cloudflare-api-token",
		"CLOUDFLARE_ACCOUNT_ID": "your-cloudflare-account-id",
		"GITHUB_TOKEN": "ghp_xxxxxxxxxxxxxxxxxxxx",
		"TURBO_TOKEN": "your-turbo-token",
		"TURBO_TEAM": "your-turbo-team"
	},

	"product": {
		"$comment": "Product-specific secrets - stored in product's Infisical project",

		"database": {
			"DATABASE_URL": "libsql://your-db.turso.io",
			"DATABASE_AUTH_TOKEN": "your-database-auth-token"
		},

		"auth": {
			"JWT_SECRET": "generate-a-64-char-random-string-for-jwt-signing",
			"JWT_REFRESH_SECRET": "generate-another-64-char-random-string-for-refresh",
			"JWT_ISSUER": "https://your-product.app",
			"JWT_AUDIENCE": "your-product-api",
			"JWT_ACCESS_EXPIRY": "15m",
			"JWT_REFRESH_EXPIRY": "7d"
		},

		"payments": {
			"STRIPE_SECRET_KEY": "sk_test_xxxxxxxxxxxxxxxxxxxx",
			"STRIPE_PUBLISHABLE_KEY": "pk_test_xxxxxxxxxxxxxxxxxxxx",
			"STRIPE_WEBHOOK_SECRET": "whsec_xxxxxxxxxxxxxxxxxxxx"
		},

		"email": {
			"RESEND_API_KEY": "re_xxxxxxxxxxxxxxxxxxxx",
			"EMAIL_FROM": "noreply@your-product.app",
			"EMAIL_REPLY_TO": "support@your-product.app"
		},

		"mobile": {
			"REVENUECAT_API_KEY": "your-revenuecat-api-key",
			"REVENUECAT_WEBHOOK_AUTH": "your-webhook-auth-header"
		},

		"analytics": {
			"SENTRY_DSN": "https://xxxxxxxx@sentry.io/xxxxxxx",
			"SENTRY_AUTH_TOKEN": "your-sentry-auth-token",
			"POSTHOG_API_KEY": "phc_xxxxxxxxxxxxxxxxxxxx",
			"POSTHOG_HOST": "https://app.posthog.com"
		},

		"storage": {
			"S3_ACCESS_KEY_ID": "your-r2-access-key-id",
			"S3_SECRET_ACCESS_KEY": "your-r2-secret-access-key",
			"S3_BUCKET": "your-bucket-name",
			"S3_ENDPOINT": "https://your-account-id.r2.cloudflarestorage.com",
			"S3_REGION": "auto"
		},

		"features": {
			"FEATURE_FLAGS": "{\"newFeature\": true, \"betaAccess\": false}",
			"DEBUG": "false",
			"LOG_LEVEL": "info"
		}
	}
}
