{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": false,
		"outDir": ".",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": [
		"*.ts",
		"typescript/**/*.ts",
		"checks/**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}
