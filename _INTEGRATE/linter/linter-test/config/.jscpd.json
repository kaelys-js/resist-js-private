{
	"$schema": "https://json.schemastore.org/jscpd.json",
	"threshold": 0,
	"minLines": 5,
	"minTokens": 50,
	"maxLines": 1000,
	"maxSize": "100kb",
	"reporters": ["json", "console"],
	"output": "./reports/jscpd",
	"absolute": false,
	"gitignore": true,
	"blame": false,
	"silent": false,
	"noSymlinks": false,
	"skipLocal": false,
	"formatsExts": {
		"javascript": ["js", "mjs", "cjs"],
		"typescript": ["ts", "mts", "cts"],
		"jsx": ["jsx"],
		"tsx": ["tsx"],
		"svelte": ["svelte"],
		"vue": ["vue"],
		"html": ["html", "htm"],
		"css": ["css", "scss", "sass", "less"],
		"json": ["json", "jsonc"],
		"yaml": ["yaml", "yml"],
		"markdown": ["md", "mdx"],
		"python": ["py"],
		"rust": ["rs"],
		"go": ["go"],
		"java": ["java"],
		"kotlin": ["kt", "kts"],
		"swift": ["swift"],
		"ruby": ["rb"],
		"php": ["php"],
		"shell": ["sh", "bash", "zsh"]
	},
	"ignore": [
		"**/*.min.js",
		"**/*.min.css",
		"**/*.bundle.js",
		"**/*.bundle.css",
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/.svelte-kit/**",
		"**/coverage/**",
		"**/target/**",
		"**/vendor/**",
		"**/.git/**",
		"**/.next/**",
		"**/.nuxt/**",
		"**/__pycache__/**",
		"**/*.lock",
		"**/pnpm-lock.yaml",
		"**/package-lock.json",
		"**/yarn.lock",
		"**/Cargo.lock",
		"**/*.snap",
		"**/*.generated.*",
		"**/*.g.dart",
		"**/*.freezed.dart"
	],
	"format": [
		"javascript",
		"typescript",
		"jsx",
		"tsx",
		"svelte",
		"vue",
		"html",
		"css",
		"python",
		"rust",
		"go"
	],
	"exitCode": 0
}
