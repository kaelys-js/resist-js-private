{
	"$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
	"rules": {
		"correctness": {
			"no-unused-vars": "warn",
			"no-undef": "error",
			"no-const-assign": "error",
			"no-dupe-keys": "error",
			"no-duplicate-case": "error",
			"no-empty-pattern": "error",
			"no-func-assign": "error",
			"no-import-assign": "error",
			"no-self-assign": "error",
			"no-self-compare": "error",
			"no-unreachable": "error",
			"use-isnan": "error",
			"valid-typeof": "error"
		},
		"suspicious": {
			"no-debugger": "warn",
			"no-console": "off",
			"no-empty": "warn",
			"no-extra-boolean-cast": "warn",
			"no-fallthrough": "warn",
			"no-shadow-restricted-names": "error"
		},
		"pedantic": {
			"eqeqeq": "warn",
			"no-caller": "error",
			"no-eval": "error",
			"no-implied-eval": "error",
			"no-new-func": "error",
			"no-new-wrappers": "error",
			"no-throw-literal": "warn"
		},
		"style": {
			"default-case-last": "warn",
			"max-lines": ["warn", { "max": 500 }],
			"no-lonely-if": "warn",
			"no-multi-assign": "warn",
			"no-nested-ternary": "warn",
			"no-unneeded-ternary": "warn",
			"prefer-exponentiation-operator": "warn"
		},
		"typescript": {
			"no-explicit-any": "warn",
			"no-non-null-assertion": "warn",
			"prefer-ts-expect-error": "warn",
			"ban-ts-comment": "warn",
			"no-unnecessary-type-assertion": "warn"
		},
		"import": {
			"no-duplicates": "error",
			"no-self-import": "error",
			"no-cycle": "warn",
			"no-useless-path-segments": "warn"
		},
		"react": {
			"jsx-key": "error",
			"jsx-no-duplicate-props": "error",
			"no-children-prop": "warn",
			"no-danger-with-children": "error",
			"no-direct-mutation-state": "error"
		}
	},
	"settings": {
		"jsx": {
			"runtime": "automatic"
		}
	},
	"ignorePatterns": [
		"node_modules",
		"dist",
		"build",
		".svelte-kit",
		"coverage",
		"*.min.js",
		"*.bundle.js"
	]
}
