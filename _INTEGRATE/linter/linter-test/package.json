{
	"name": "linter-test",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		// TODO: prefix with "qa:"
		"lint": "node scripts/lint.mjs .",
		"lint:fix": "node scripts/lint.mjs --fix .",
		"lint:file": "node scripts/lint.mjs",
		"lint:json": "node scripts/lint.mjs --json",
		"lint:rules": "node scripts/lint.mjs --list-rules",
		"lint:custom": "node scripts/lint.mjs --only-custom-rules",
		"format": "pnpm format:biome && pnpm format:yaml && pnpm format:toml && pnpm format:shell",
		"format:biome": "biome format --write .",
		"format:yaml": "prettier --write \"**/*.{yml,yaml}\"",
		"format:toml": "taplo format",
		"format:shell": "shfmt -w -i 2 .",
		"format:file": "biome format --write",
		"format:file:yaml": "prettier --write",
		"format:file:toml": "taplo format",
		"format:file:shell": "shfmt -w -i 2",
		"build:rules": "tsc -p scripts/rules/tsconfig.json",
		"build:extension": "pnpm --filter resist-linter compile",
		"watch:extension": "pnpm --filter resist-linter watch"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^20.0.0",
		"oxc-parser": "^0.45.0",
		"oxlint": "^0.12.0",
		"prettier": "^3.4.0",
		"@taplo/cli": "^0.7.0",
		"typescript": "^5.3.0",
		"yaml": "^2.6.0"
	}
}
