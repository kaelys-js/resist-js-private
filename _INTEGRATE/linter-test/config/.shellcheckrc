# ShellCheck configuration
# https://www.shellcheck.net/wiki/

# Set default shell dialect
shell=bash

# Enable all optional checks
enable=all

# Disable specific checks:
# SC1090 - Can't follow non-constant source
# SC1091 - Not following source (file not found)
# SC2034 - Variable appears unused (common in sourced files)
# SC2154 - Variable referenced but not assigned (often from env)
disable=SC1090,SC1091

# Treat these as source paths for finding sourced files
source-path=SCRIPTDIR

# Use external sources
external-sources=true
