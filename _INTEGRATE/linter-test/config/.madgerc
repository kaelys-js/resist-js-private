{
	"detectiveOptions": {
		"ts": {
			"skipTypeImports": true,
			"mixedImports": true
		},
		"tsx": {
			"skipTypeImports": true,
			"mixedImports": true
		},
		"es6": {
			"mixedImports": true
		}
	},
	"fileExtensions": [
		"js",
		"jsx",
		"ts",
		"tsx",
		"mjs",
		"cjs",
		"mts",
		"cts",
		"svelte",
		"vue"
	],
	"excludeRegExp": [
		"node_modules",
		"dist",
		"build",
		"\\.svelte-kit",
		"coverage",
		"\\.test\\.",
		"\\.spec\\.",
		"__tests__",
		"__mocks__",
		"\\.d\\.ts$"
	],
	"includeNpm": false,
	"tsConfig": "tsconfig.json",
	"webpackConfig": null,
	"baseDir": null,
	"dependencyFilter": null,
	"layout": "dot"
}
