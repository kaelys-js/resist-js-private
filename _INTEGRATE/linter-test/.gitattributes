# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts text
*.tsx text
*.js text
*.mjs text
*.cjs text
*.jsx text
*.json text
*.jsonc text
*.yaml text
*.yml text
*.toml text
*.md text
*.mdx text
*.html text
*.css text
*.scss text
*.sass text
*.less text
*.svg text
*.xml text
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.py text
*.rb text
*.go text
*.rs text
*.sql text

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Lock files - don't diff
pnpm-lock.yaml -diff

# Linguist settings
*.mjs linguist-language=JavaScript
*.cjs linguist-language=JavaScript
*.mts linguist-language=TypeScript
*.cts linguist-language=TypeScript
