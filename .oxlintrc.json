{
	"$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config/main/schema.json",
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error"
	},
	"plugins": ["typescript", "unicorn", "import", "promise", "vitest", "jsdoc", "node"],
	"globals": {
		"console": "readonly",
		"setTimeout": "readonly",
		"clearTimeout": "readonly",
		"setInterval": "readonly",
		"clearInterval": "readonly",
		"process": "readonly",
		"crypto": "readonly",
		"performance": "readonly",
		"Response": "readonly",
		"Request": "readonly",
		"Headers": "readonly",
		"AbortController": "readonly",
		"AbortSignal": "readonly",
		"URL": "readonly",
		"URLSearchParams": "readonly",
		"TextEncoder": "readonly",
		"TextDecoder": "readonly",
		"fetch": "readonly",
		"queueMicrotask": "readonly",
		"structuredClone": "readonly",
		"globalThis": "readonly",
		"Intl": "readonly",
		"navigator": "readonly",
		"window": "readonly",
		"document": "readonly",
		"requestAnimationFrame": "readonly",
		"cancelAnimationFrame": "readonly",
		"Map": "readonly",
		"Set": "readonly",
		"WeakMap": "readonly",
		"WeakSet": "readonly",
		"Promise": "readonly",
		"Symbol": "readonly",
		"Proxy": "readonly",
		"Reflect": "readonly",
		"RegExp": "readonly",
		"Error": "readonly",
		"TypeError": "readonly",
		"RangeError": "readonly",
		"SyntaxError": "readonly",
		"atob": "readonly",
		"btoa": "readonly",
		"ErrorEvent": "readonly",
		"$state": "readonly",
		"$derived": "readonly",
		"$effect": "readonly",
		"$props": "readonly",
		"$bindable": "readonly",
		"$inspect": "readonly",
		"HTMLElement": "readonly",
		"HTMLCanvasElement": "readonly",
		"HTMLInputElement": "readonly",
		"localStorage": "readonly",
		"GPUPowerPreference": "readonly",
		"ResizeObserver": "readonly",
		"require": "readonly"
	},
	"rules": {
		"no-inline-comments": "off",
		"max-lines": "off",
