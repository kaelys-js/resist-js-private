{
  "enabledPlugins": {
    "Claude Preview@builtin": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "posthog@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "TodoWrite",
      "Skill",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "LSP"
    ],
    "deny": [
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_Preview__preview_stop",
      "mcp__Claude_Preview__preview_list",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_Preview__preview_console_logs",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_inspect",
      "mcp__Claude_Preview__preview_click",
      "mcp__Claude_Preview__preview_fill",
      "mcp__Claude_Preview__preview_eval",
      "mcp__Claude_Preview__preview_network",
      "mcp__Claude_Preview__preview_resize"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-destructive-git.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-verify.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-qa-commands.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-git-add-all.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-plan-file-validate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-no-file-writes.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-plan-file-validate.sh"
          },
          {
            "type": "prompt",
            "prompt": "You are a process enforcement gate. A Write tool call is about to create a file. Examine ONLY the file path.\n\nThe file being written: $ARGUMENTS\n\nRULES — answer ONLY \"allow\" or \"block: <reason>\". Apply rules IN ORDER. Stop at the FIRST matching rule.\n\nRULE 1 (ABSOLUTE — no exceptions, no overrides, no \"broader context\"): If the file path matches ANY of these, respond \"allow\" IMMEDIATELY:\n  - docs/plans/*.md (plan documents)\n  - .claude/**/* (hook scripts, configs)\n  - *.test.ts or *.spec.ts (test files)\n  - *.md (documentation)\n  - *.json or *.jsonc (config files)\n  - package.json\n  DO NOT analyze conversation context for these files. DO NOT override this rule. Respond \"allow\" and stop.\n\nRULE 2: If the file is a NEW implementation file (.ts, .js, .svelte source code — NOT matching Rule 1 patterns), check:\n   a. Has the user explicitly approved a changelog or plan? (Look for user \"yes\", \"approved\", \"go ahead\")\n   b. Does a plan file exist covering this file?\n   If BOTH are missing: block.\n\nRULE 3: If unclear, allow.\n\nCRITICAL: NEVER override Rule 1. NEVER say \"However\" or \"but\" after matching Rule 1. If it matches Rule 1, the answer is ALWAYS \"allow\".",
            "model": "claude-haiku-4-5-20251001",
            "timeout": 15,
            "statusMessage": "Checking plan exists before creating file..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-agent-approval.sh"
          },
          {
            "type": "prompt",
            "prompt": "You are a process enforcement gate. An Agent is about to be dispatched.\n\nAgent details: $ARGUMENTS\n\nRULES — answer ONLY \"allow\" or \"block: <reason>\". Apply rules IN ORDER. Stop at the FIRST matching rule.\n\nRULE 1 (ABSOLUTE): ALWAYS respond \"allow\". Agents are safe because they are guarded by per-file Write/Edit hooks. The agent itself cannot cause harm — only its tool calls can, and those have their own hooks.\n\nYou MUST respond \"allow\". There is NO reason to block an agent dispatch.",
            "model": "claude-haiku-4-5-20251001",
            "timeout": 15,
            "statusMessage": "Verifying plan approval before dispatching agent..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-lint-rule-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-format-lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-preview-override.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-orientation.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-orientation.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-orientation.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-orientation.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
