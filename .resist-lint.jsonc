    "valibot/no-orphan-schemas": "error",
    "valibot/no-orphan-types": "error",
    "valibot/no-partial-infer": "error",
    "valibot/no-passthrough": "error",
    "valibot/no-recursive-without-lazy": "error",
    "valibot/no-reexport-infer": "error",
    "valibot/no-schema-in-component": "error",
    "valibot/no-schema-in-loop": "error",
    "valibot/no-transform-side-effects": "error",
    "valibot/no-type-cast-after-parse": "error",
    "valibot/no-unsafe-coerce": "error",
    "valibot/no-yup": "error",
    "valibot/no-zod": "error",
    "valibot/one-schema-per-file": "error",
    "valibot/prefer-branded-types": "error",
    "valibot/prefer-methods": "error",
    "valibot/prefer-picklist": "error",
    "valibot/prefer-pipe": "error",
    "valibot/readonly-parse-result": "error",
    "valibot/require-description": "error",
    "valibot/require-error-map": "error",
    "valibot/require-error-mapping": "error",
    "valibot/revalidate-on-change": "error",
    "valibot/schema-file-location": "error",
    "valibot/schema-type-pair": "error",
    "valibot/type-alias-from-schema": "error",
    "valibot/validate-boundaries": "error",
    "valibot/validate-function-output": "error",
    "package/no-git-deps": "error",
    "package/no-hoisted-dep": "error",
    "package/no-peer-deps": "error",
    "package/no-root-only-scripts": "error",
    "package/no-tsc-dependency": "error",
    "package/no-ts-node": "error",
    "package/no-vitest-config": "error",
