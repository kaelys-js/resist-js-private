    "svelte5/require-snippet-typing": "off",
    "sync/filter-patterns": "off",
    "sync/lefthook-scripts": "off",
    "sync/onboarding-steps": "off",
    "sync/pnpm-workspace": "off",
    "sync/tsconfig-paths": "off",
    "sync/turbo-tasks": "off",
    "sync/workflow-scripts": "off",
    "testing/require-colocated-tests": "off",
    "testing/require-e2e-location": "off",
