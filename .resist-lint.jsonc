{
  "$schema": "./.resist-lint.schema.json",
  "include": ["packages"],
  "exclude": [
    "node_modules",
    ".git",
    ".svelte-kit",
    "dist",
    "build",
    "coverage",
    ".turbo",
    "_INTEGRATE",
    "*.test.ts",
    "*.d.ts",
    "packages/shared/utils/cli"
  ],
  "extensions": [".ts", ".svelte.ts", ".mjs"],
  "rules": {
    "comments/no-lint-disable": "error",
    "comments/require-blank-line-groups": "error",
    "comments/require-section-marker-style": "error",
    "comments/require-section-order": "error",
    "imports/no-barrel-files": "error",
    "imports/no-js-extension": "error",
    "imports/no-raw-json": "error",
    "imports/no-raw-node-imports": "error",
    "imports/no-reexport": "error",
    "imports/no-relative-imports": "error",
    "imports/require-import-groups": "error",
    "jsdoc/param-type-match": "error",
    "jsdoc/require-example": "error",
    "jsdoc/require-jsdoc": "error",
    "jsdoc/require-module": "error",
    "jsdoc/require-param": "error",
    "jsdoc/require-returns": "error",
    "jsdoc/require-schema-link": "error",
    "jsdoc/validate-example": "error",
    "naming/camel-case-vars": "error",
    "naming/constant-screaming-case": "error",
    "naming/pascal-case-types": "error",
    "naming/svelte-file-pascal-case": "error",
    "naming/ts-file-kebab-case": "error",
    "result/check-before-access": "error",
    "result/no-ignore-result": "error",
    "result/no-redundant-ok-guard": "error",
    "result/no-result-fallback": "error",
    "result/no-ternary-fallback": "error",
    "result/require-ok-return": "error",
    "result/require-result-type": "error",
    "result/validate-function-input": "error",
    "testing/require-colocated-tests": "error",
    "testing/require-test-suffix": "error",
    "testing/require-e2e-location": "error",
    "testing/require-integration-location": "warn",
    "typescript/no-bare-as-cast": "error",
    "typescript/no-bare-data-types": "error",
    "typescript/no-builtin-types": "error",
    "typescript/no-default-params": "error",
    "typescript/no-empty-catch": "error",
    "typescript/no-generic-function-type": "error",
    "typescript/no-module-side-effects": "error",
    "typescript/no-throw": "error",
    "typescript/no-union-null": "error",
    "typescript/no-union-params": "error",
    "typescript/require-const-comment": "error",
    "typescript/require-function-schema": "error",
    "typescript/require-non-negative-integer": "error",
    "typescript/require-return-type": "error",
    "typescript/require-svelte-ts-extension": "error",
    "typescript/require-type-annotation": "error",
    "valibot/namespace-import": "error",
    "valibot/no-direct-safeparse": "error",
    "valibot/no-duplicate-schema": "error",
    "valibot/no-generic-string-schema": "error",
    "valibot/no-parse": "error",
    "valibot/prefer-shared-schema": "error",
    "valibot/prefer-template-literal": "error",
    "valibot/require-field-docs": "error",
    "valibot/require-generic-schema": "error",
    "valibot/require-min-length": "error",
    "valibot/require-schema-suffix": "error",
    "valibot/require-strict-object": "error",
    "valibot/await-async-parse": "error",
    "valibot/colocate-schema-type": "error",
    "valibot/consistent-infer": "error",
    "valibot/consistent-nullability": "error",
    "valibot/discriminated-unions": "error",
    "valibot/error-map-all-locales": "error",
    "valibot/error-map-complete": "error",
    "valibot/explicit-undefined": "error",
    "valibot/export-schema-and-type": "error",
    "valibot/import-type-only": "error",
    "valibot/limit-union-size": "error",
    "valibot/no-any-schema": "error",
    "valibot/no-class-validator": "error",
    "valibot/no-duplicate-keys": "error",
    "valibot/no-empty-object": "error",
    "valibot/no-expensive-regex": "error",
    "valibot/no-fallback-required": "error",
    "valibot/no-ignore-issues": "error",
    "valibot/no-inline-error-message": "error",
    "valibot/no-inline-infer": "error",
    "valibot/no-io-ts": "error",
    "valibot/no-joi": "error",
    "valibot/no-loose-tuples": "error",
    "valibot/no-manual-types": "error",
    "valibot/no-mutate-after-parse": "error",
