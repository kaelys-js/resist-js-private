    "package/no-vitest-config": "off",
    "package/no-workspace-dep": "off",
    "package/no-workspace-self-ref": "off",
    "package/require-project-test": "off",
    "package/require-readme": "off",
    "package/require-scope": "off",
    "package/require-shared-config": "off",
    "package/require-standard-scripts": "off",
    "package/valid-project-ref": "off",
    "package/valid-tsconfig": "off",
    "primitives/division-by-zero": "off",
    "primitives/no-array-hole": "off",
    "primitives/no-array-index-string": "off",
    "primitives/no-array-length-mutation": "off",
    "primitives/no-bigint-number-mix": "off",
    "primitives/no-compare-different-types": "off",
    "primitives/no-date-arithmetic": "off",
