{
  "$schema": "./.resist-lint.schema.json",
  "include": ["packages"],
  "exclude": [
    "node_modules",
    ".git",
    ".svelte-kit",
    "dist",
    "build",
    "coverage",
    ".turbo",
    "_INTEGRATE",
    "__mocks__"
  ],
  "extensions": [".ts", ".svelte.ts", ".svelte", ".astro", ".html", ".vue", ".md", ".mdx", ".mjs"],
  "rules": {
    "comments/no-lint-disable": "off",
    "comments/require-blank-line-groups": "off",
    "comments/require-section-marker-style": "off",
    "comments/require-section-order": "off",
    "complexity/array-size-warning": "off",
    "complexity/no-array-method-in-loop": "off",
    "complexity/no-await-in-loop": "off",
    "complexity/no-concat-in-loop": "off",
    "complexity/no-dom-query-in-loop": "off",
    "complexity/no-filter-map-chain": "off",
    "complexity/no-index-of-in-loop": "off",
    "complexity/no-json-parse-in-loop": "off",
    "complexity/no-nested-array-iteration": "off",
    "complexity/no-regex-in-loop": "off",
    "complexity/no-repeated-traversal": "off",
    "complexity/no-sort-in-loop": "off",
    "complexity/no-spread-in-reduce": "off",
    "complexity/prefer-map-for-lookup": "off",
    "complexity/prefer-set-for-existence": "off",
    "complexity/recursive-depth": "off",
    "directives/max-suppressions-per-file": "off",
    "directives/no-biome-ignore": "error",
    "directives/no-eslint-disable": "error",
    "directives/no-generic-any-assertion": "error",
    "directives/no-oxlint-ignore": "error",
    "directives/no-prettier-ignore": "error",
    "directives/no-suppression-in-new-code": "off",
    "directives/no-ts-expect-error-on-any": "error",
    "directives/no-ts-ignore": "error",
    "directives/no-ts-nocheck": "error",
    "directives/no-type-assertion-chain": "off",
    "directives/require-ts-expect-error-reason": "off",
    "hygiene/no-bare-catch": "off",
    "hygiene/no-dead-locale-keys": "off",
    "hygiene/no-duplicate-function-signatures": "off",
    "hygiene/no-orphaned-exports": "off",
    "plans/files-exist": "error",
    "plans/no-empty-plan-sections": "error",
    "plans/no-incomplete-tasks": "error",
    "plans/no-template-placeholders": "error",
    "plans/require-concrete-verification": "error",
    "plans/require-test-files": "error",
    "plans/require-plan-structure": "error",
    "plans/status-dependency-order": "error",
    "imports/no-barrel-files": "off",
    "imports/no-js-extension": "off",
    "imports/no-raw-json": "off",
    "imports/no-raw-node-imports": "off",
    "imports/no-reexport": "off",
    "imports/no-relative-imports": "off",
    "imports/require-import-groups": "off",
    "jsdoc/param-type-match": "off",
    "jsdoc/require-example": "off",
    "jsdoc/require-jsdoc": "off",
    "jsdoc/require-module": "off",
    "jsdoc/require-param": "off",
    "jsdoc/require-returns": "off",
    "jsdoc/require-schema-link": "off",
    "jsdoc/validate-example": "off",
    "naming/camel-case-vars": "off",
    "naming/constant-screaming-case": "off",
    "naming/svelte-file-pascal-case": "off",
    "naming/ts-file-kebab-case": "off",
    "package/names-valid": "off",
    "package/no-git-deps": "off",
    "package/no-hoisted-dep": "off",
    "package/no-peer-deps": "off",
    "package/no-root-only-scripts": "off",
    "package/no-ts-node": "off",
