    "primitives/no-new-date-string-parse": "off",
    "primitives/no-object-prototype-access": "off",
    "primitives/no-regex-on-untrusted": "off",
    "primitives/no-relational-null-undefined": "off",
    "primitives/no-string-index-unicode": "off",
    "primitives/no-string-length-unicode": "off",
    "primitives/no-toFixed-rounding": "off",
    "primitives/no-unsafe-integer": "off",
    "primitives/object-is-for-special": "off",
    "primitives/prefer-bigint-for-ids": "off",
    "primitives/prefer-math-trunc": "off",
    "primitives/prefer-normalize-comparison": "off",
    "primitives/use-number-is-finite": "off",
    "primitives/use-number-is-integer": "off",
    "result/check-before-access": "off",
    "result/no-ignore-result": "off",
    "result/no-redundant-ok-guard": "off",
    "result/no-result-fallback": "off",
    "result/no-ternary-fallback": "off",
    "result/require-ok-return": "off",
    "result/require-result-type": "off",
    "result/validate-function-input": "off",
    "svelte5-config/cloudflare-adapter-settings": "off",
    "svelte5-config/csp-headers": "off",
    "svelte5-config/env-prefix-consistency": "off",
    "svelte5-config/kit-alias-consistency": "off",
    "svelte5-config/no-deprecated-options": "off",
