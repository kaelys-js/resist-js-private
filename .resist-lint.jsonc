    "workspace/svg-no-mask-fragment": "warn",
    "workspace/svg-requires-aria-attrs": "warn",
    "workspace/svg-title-desc-requires-lang": "warn",
    "workspace/no-webp-icons": "error",
    "workspace/no-inline-svg-in-source": "error",
    "workspace/no-webp-in-css": "warn",
    "workspace/no-raw-svg-in-components": "error",

    // Phase 32 — Image Quality, ICO/WebP Binary Validation Rules
    "workspace/webp-max-size": "warn",
    "workspace/webp-no-lossless": "warn",
    "workspace/webp-no-metadata": "warn",
    "workspace/ico-min-resolution": "warn",
    "workspace/no-misleading-image-extension": "error",
    "workspace/svg-valid-xml": "error",
    "workspace/ico-requires-multiresolution": "error",
    "workspace/ico-optimal-palette": "warn",
    "workspace/webp-no-color-profile": "warn",
    "workspace/webp-yuv420-required": "warn",

    // Phase 33 — GitLab CI, Shell Docblocks, Workspace & MR Rules
    "workspace/gitlab-ci-file-required": "error",
    "workspace/gitlab-ci-schema-header": "error",
    "workspace/gitlab-ci-yaml-syntax": "error",
    "workspace/gitlab-ci-stages-declared": "error",
    "workspace/gitlab-ci-includes-valid": "error",
    "workspace/shell-function-docblocks": "error",
    "workspace/gitlab-ci-jobs-have-script": "error",
    "workspace/gitlab-ci-standard-naming": "warn",
    "workspace/wrangler-authenticated": "warn",
    "workspace/gitlab-ci-stages-standard": "error",
    "workspace/cli-tools-help-version": "warn",
    "workspace/workspace-spelling": "warn",
    "workspace/mr-title-format": "error",
    "workspace/mr-description-required": "error",

    // Phase 34 — MR Validation Rules
    "workspace/mr-label-enforcement": "error",
    "workspace/mr-target-branch-protected": "error",
    "workspace/mr-draft-block": "error",
    "workspace/mr-conflicting-labels": "error",
    "workspace/mr-size-limit": "warn",
    "workspace/mr-assignee-required": "error",
    "workspace/mr-reviewer-required": "error",
    "workspace/mr-blocking-discussions": "error",
    "workspace/mr-wip-commit-check": "error",
    "workspace/mr-approval-required": "error",
    "workspace/mr-branch-source-rules": "error",
    "workspace/mr-codeowners-approval": "error",
    "workspace/mr-labels-required-per-scope": "error",
    "workspace/mr-dependency-changes-reviewed": "error",
    "workspace/mr-ci-pipeline-passed": "error",
    "workspace/mr-up-to-date-with-target": "error",

    // Phase 35 — MR Metadata, Valibot & Vitest Rules
    "workspace/mr-cherry-pick-label": "error",
    "workspace/mr-test-coverage-diff": "warn",
    "workspace/mr-label-format": "error",
    "workspace/mr-release-label-required": "error",
    "workspace/mr-no-force-push-after-review": "error",
    "workspace/mr-license-change-reviewed": "error",
    "workspace/mr-config-changes-approved": "error",
    "workspace/mr-open-too-long": "warn",
    "workspace/mr-automerge-not-enabled-by-default": "error",
    "workspace/mr-label-conflict-matrix": "error",
    "workspace/mr-sensitive-path-changes": "error",
    "workspace/mr-test-or-benchmark-regressions": "error",
    "workspace/valibot-consistency": "warn",
    "workspace/vitest-config-and-coverage": "error",
    "workspace/vitest-config-and-usage": "error",

    // Phase 36 — DangerJS PR Rules Migration
    "workspace/pr-svg-optimized": "warn",
    "workspace/pr-branch-commit-mismatch": "error",
    "workspace/pr-description-required": "error",
    "workspace/pr-no-merge-commits": "error",
    "workspace/pr-wip-warning": "warn",

    // Phase 37 — O(n) Complexity Rules
    "complexity/no-nested-array-iteration": "warn",
    "complexity/no-array-method-in-loop": "warn",
    "complexity/prefer-map-for-lookup": "warn",
    "complexity/prefer-set-for-existence": "warn",
    "complexity/no-repeated-traversal": "warn",
    "complexity/no-index-of-in-loop": "warn",
    "complexity/no-spread-in-reduce": "warn",
    "complexity/no-concat-in-loop": "warn",
    "complexity/no-dom-query-in-loop": "warn",
    "complexity/no-regex-in-loop": "warn",
    "complexity/no-sort-in-loop": "warn",
    "complexity/no-json-parse-in-loop": "warn",
    "complexity/no-await-in-loop": "warn",
    "complexity/no-filter-map-chain": "warn",
    "complexity/array-size-warning": "warn",
    "complexity/recursive-depth": "warn",

    // Primitives — Number Safety
    "primitives/no-unsafe-integer": "error",
    "primitives/no-float-equality": "error",
    "primitives/no-infinity-arithmetic": "warn",
    "primitives/use-number-is-finite": "error",
    "primitives/use-number-is-integer": "warn",
    "primitives/no-toFixed-rounding": "warn",

    // Primitives — BigInt
    "primitives/prefer-bigint-for-ids": "warn",
    "primitives/no-bigint-number-mix": "error",

    // Primitives — Math
    "primitives/no-math-random-crypto": "error",
    "primitives/division-by-zero": "error",
    "primitives/no-modulo-negative": "warn",
    "primitives/prefer-math-trunc": "warn",
    "primitives/no-lossy-math-operation": "warn",

    // Primitives — String Unicode
    "primitives/no-string-length-unicode": "warn",
    "primitives/no-string-index-unicode": "warn",
    "primitives/prefer-normalize-comparison": "warn",
    "primitives/no-regex-on-untrusted": "error",

    // Primitives — Date
    "primitives/no-new-date-string-parse": "warn",
    "primitives/no-date-mutation": "warn",
    "primitives/no-date-arithmetic": "warn",

    // Primitives — JSON
    "primitives/no-json-bigint": "warn",
    "primitives/no-json-undefined": "warn",
    "primitives/no-json-circular": "error",
    "primitives/no-json-nan-infinity": "warn",

    // Primitives — Comparison
    "primitives/no-compare-different-types": "error",
    "primitives/no-relational-null-undefined": "error",
    "primitives/object-is-for-special": "warn",

    // Primitives — Array
    "primitives/no-array-hole": "error",
    "primitives/no-array-length-mutation": "warn",
    "primitives/no-array-index-string": "error",

    // Primitives — Object
    "primitives/no-object-prototype-access": "warn",
    "primitives/no-in-operator-primitive": "error",

    // Directives — TypeScript Suppressions
    "directives/no-ts-ignore": "error",
    "directives/no-ts-nocheck": "error",
    "directives/require-ts-expect-error-reason": "error",
    "directives/no-ts-expect-error-on-any": "warn",

    // Directives — Third-Party Linter Suppressions
    "directives/no-eslint-disable": "error",
    "directives/no-prettier-ignore": "error",
    "directives/no-biome-ignore": "error",
    "directives/no-oxlint-ignore": "error",

    // Directives — Type Assertion Safety
    "directives/no-type-assertion-chain": "error",
    "directives/no-generic-any-assertion": "error",

    // Directives — Suppression Density
    "directives/max-suppressions-per-file": "warn",
    "directives/no-suppression-in-new-code": "warn"
  },
  "ruleOptions": {
    "comments/no-lint-disable": {
      "allowedTargets": ["max-lines", "max-lines-per-function"]
    }
  },
  "overrides": [
    // =========================================================================
    // Test files — most rules don't apply
    // =========================================================================
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "jsdoc/require-module": "off",
        "jsdoc/require-jsdoc": "off",
        "jsdoc/require-example": "off",
        "jsdoc/require-schema-link": "off",
        "valibot/no-duplicate-schema": "off",
        "valibot/no-generic-string-schema": "off",
        "valibot/prefer-template-literal": "off",
        "valibot/prefer-shared-schema": "off",
        "valibot/require-schema-suffix": "off",
        "valibot/require-min-length": "off",
        "valibot/await-async-parse": "off",
        "valibot/colocate-schema-type": "off",
        "valibot/consistent-infer": "off",
        "valibot/consistent-nullability": "off",
        "valibot/discriminated-unions": "off",
        "valibot/error-map-all-locales": "off",
        "valibot/error-map-complete": "off",
        "valibot/explicit-undefined": "off",
        "valibot/export-schema-and-type": "off",
        "valibot/import-type-only": "off",
        "valibot/limit-union-size": "off",
        "valibot/no-any-schema": "off",
        "valibot/no-class-validator": "off",
        "valibot/no-duplicate-keys": "off",
        "valibot/no-empty-object": "off",
        "valibot/no-expensive-regex": "off",
        "valibot/no-fallback-required": "off",
        "valibot/no-ignore-issues": "off",
        "valibot/no-inline-error-message": "off",
        "valibot/no-inline-infer": "off",
        "valibot/no-io-ts": "off",
        "valibot/no-joi": "off",
        "valibot/no-loose-tuples": "off",
        "valibot/no-manual-types": "off",
        "valibot/no-mutate-after-parse": "off",
        "valibot/no-nested-optional": "off",
        "valibot/no-omit-pick-infer": "off",
        "valibot/no-optional-heavy-object": "off",
        "valibot/no-orphan-schemas": "off",
        "valibot/no-orphan-types": "off",
        "valibot/no-partial-infer": "off",
        "valibot/no-passthrough": "off",
        "valibot/no-recursive-without-lazy": "off",
        "valibot/no-reexport-infer": "off",
        "valibot/no-schema-in-component": "off",
