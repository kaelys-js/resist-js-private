{
  "name": "@resist/vscode",
  "displayName": "Resist",
  "description": "Custom linting with real-time diagnostics and auto-fix for the Resist workspace",
  "version": "0.0.1",
  "publisher": "resist",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "resist.lint.file",
        "title": "Lint Current File",
        "category": "Resist"
      },
      {
        "command": "resist.lint.workspace",
        "title": "Lint Workspace",
        "category": "Resist"
      },
      {
        "command": "resist.lint.fix",
        "title": "Fix All Auto-fixable",
        "category": "Resist"
      },
      {
        "command": "resist.lint.clear",
        "title": "Clear Diagnostics",
        "category": "Resist"
      },
      {
        "command": "resist.lint.listRules",
        "title": "List Available Rules",
        "category": "Resist"
      },
      {
        "command": "resist.lint.restart",
        "title": "Restart Linter",
        "category": "Resist"
      },
      {
        "command": "resist.lint.showOutput",
        "title": "Show Output",
        "category": "Resist"
      },
      {
        "command": "resist.lint.staged",
        "title": "Lint Staged Changes",
        "category": "Resist"
      },
      {
        "command": "resist.lint.uncommitted",
        "title": "Lint Uncommitted Changes",
        "category": "Resist"
      }
    ],
    "configuration": {
      "title": "Resist",
      "properties": {
        "resist.lint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the linter"
        },
        "resist.lint.onSave": {
          "type": "boolean",
          "default": true,
          "description": "Lint files on save"
        },
        "resist.lint.onType": {
          "type": "boolean",
          "default": true,
          "description": "Lint files as you type (with debounce)"
        },
        "resist.lint.onOpen": {
          "type": "boolean",
          "default": true,
          "description": "Lint files when opened"
        },
        "resist.lint.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Debounce delay for lint-on-type (ms)"
        },
        "resist.lint.maxProblems": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum number of problems to report per file"
        },
        "resist.lint.stage": {
          "type": "string",
          "default": "lint",
          "enum": [
            "lint",
            "check",
            "pre-commit",
            "build",
            "ci",
            "test"
          ],
          "description": "Stage filter for custom rules"
        },
        "resist.lint.categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Category filter for custom rules (empty = all)"
        },
        "resist.lint.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra CLI arguments passed to resist-lint"
        },
        "resist.lint.cache": {
          "type": "boolean",
          "default": true,
          "description": "Enable file hash caching for incremental lint runs"
        },
        "resist.lint.quiet": {
          "type": "boolean",
          "default": false,
          "description": "Suppress warnings, show errors only"
        },
        "resist.lint.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logging to the output channel"
        },
        "resist.lint.severityOverride": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "error",
            "warn",
            "off"
          ],
          "description": "Global severity override for all rules (empty = use rule defaults)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsgo -p ./",
    "watch": "tsgo -w -p ./",
    "typecheck": "tsgo --noEmit -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.0",
    "vitest": "*"
  }
}
