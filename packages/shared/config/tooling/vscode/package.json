{
  "name": "@resist/vscode",
  "displayName": "Resist Tooling",
  "description": "Real-time linting, auto-fix, and workspace tooling for the Resist monorepo",
  "version": "0.0.1",
  "publisher": "resist",
  "private": true,
  "license": "MIT",
  "preview": true,
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "resist",
    "linter",
    "formatter",
    "monorepo",
    "tooling",
    "diagnostics",
    "code-actions"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelys-js/resist-js-private",
    "directory": "packages/shared/config/tooling/vscode"
  },
  "homepage": "https://github.com/kaelys-js/resist-js-private/tree/main/packages/shared/config/tooling/vscode#readme",
  "bugs": {
    "url": "https://github.com/kaelys-js/resist-js-private/issues"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension executes CLI tools from the workspace and requires a trusted environment."
    }
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "resist.lint.file",
        "title": "Lint Current File",
        "category": "Resist"
      },
      {
        "command": "resist.lint.workspace",
        "title": "Lint All Files in Workspace",
        "category": "Resist"
      },
      {
        "command": "resist.lint.fix",
        "title": "Apply All Auto-Fixes in Current File",
        "category": "Resist"
      },
      {
        "command": "resist.lint.clear",
        "title": "Clear All Diagnostics",
        "category": "Resist"
      },
      {
        "command": "resist.lint.listRules",
        "title": "Show Available Lint Rules",
        "category": "Resist"
      },
      {
        "command": "resist.lint.restart",
        "title": "Restart Linter (Clear Cache & Re-Lint)",
        "category": "Resist"
      },
      {
        "command": "resist.lint.showOutput",
        "title": "Show Output Channel",
        "category": "Resist"
      },
      {
        "command": "resist.lint.staged",
        "title": "Lint Only Staged Changes (git)",
        "category": "Resist"
      },
      {
        "command": "resist.lint.uncommitted",
        "title": "Lint Only Uncommitted Changes (git)",
        "category": "Resist"
      },
      {
        "command": "resist.lint.previewFixes",
        "title": "Preview All Fixes in Diff View",
        "category": "Resist"
      },
      {
        "command": "resist.lint.showTiming",
        "title": "Show Per-Rule Performance Timing",
        "category": "Resist"
      },
      {
        "command": "resist.lint.filterByCategory",
        "title": "Filter Diagnostics by Rule Category",
        "category": "Resist"
      },
      {
        "command": "resist.lint.clearFilter",
        "title": "Clear Diagnostic Category Filter",
        "category": "Resist"
      },
      {
        "command": "resist.lint.removeUnusedImports",
        "title": "Remove Unused Imports in Current File",
        "category": "Resist"
      },
      {
        "command": "resist.lint.changeStage",
        "title": "Change Active Lint Stage",
        "category": "Resist"
      },
      {
        "command": "resist.lint.clearOutput",
        "title": "Clear Output Channel",
        "category": "Resist"
      },
      {
        "command": "resist.lint.toggleEnable",
        "title": "Pause / Resume Linter",
        "category": "Resist"
      },
      {
        "command": "resist.lint.statusBarMenu",
        "title": "Status Bar Menu",
        "category": "Resist"
      },
      {
        "command": "resist.panel.expandAll",
        "title": "Expand All Sections",
        "category": "Resist",
        "icon": "$(expand-all)"
      },
      {
        "command": "resist.panel.filter",
        "title": "Filter Lint Issues",
        "category": "Resist",
        "icon": "$(filter)"
      },
      {
        "command": "resist.panel.clearFilter",
        "title": "Clear Filter",
        "category": "Resist",
        "icon": "$(close)"
      },
      {
        "command": "resist.panel.menu",
        "title": "Resist Actions",
        "category": "Resist",
        "icon": "$(ellipsis)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "resist",
          "title": "Resist",
          "icon": "resources/resist-panel.svg"
        }
      ]
    },
    "views": {
      "resist": [
        {
          "id": "resist.panel",
          "name": "Resist",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "resist.panel",
        "contents": "No workspace detected. Open a folder to start linting and formatting.\n\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "resist.panel.expandAll",
          "when": "view == resist.panel",
          "group": "navigation@1"
        },
        {
          "command": "resist.panel.filter",
          "when": "view == resist.panel",
          "group": "navigation@2"
        },
        {
          "command": "resist.panel.clearFilter",
          "when": "view == resist.panel",
          "group": "navigation@3"
        },
        {
          "command": "resist.lint.toggleEnable",
          "when": "view == resist.panel",
          "group": "1_control@1"
        },
        {
          "command": "resist.lint.restart",
          "when": "view == resist.panel",
          "group": "1_control@2"
        },
        {
          "command": "resist.lint.file",
          "when": "view == resist.panel",
          "group": "2_lint@1"
        },
        {
          "command": "resist.lint.workspace",
          "when": "view == resist.panel",
          "group": "2_lint@2"
        },
        {
          "command": "resist.lint.staged",
          "when": "view == resist.panel",
          "group": "2_lint@3"
        },
        {
          "command": "resist.lint.uncommitted",
          "when": "view == resist.panel",
          "group": "2_lint@4"
        },
        {
          "command": "resist.lint.fix",
          "when": "view == resist.panel",
          "group": "3_fix@1"
        },
        {
          "command": "resist.lint.previewFixes",
          "when": "view == resist.panel",
          "group": "3_fix@2"
        },
        {
          "command": "resist.lint.removeUnusedImports",
          "when": "view == resist.panel",
          "group": "3_fix@3"
        },
        {
          "command": "resist.lint.filterByCategory",
          "when": "view == resist.panel",
          "group": "4_filter@1"
        },
        {
          "command": "resist.lint.clearFilter",
          "when": "view == resist.panel",
          "group": "4_filter@2"
        },
        {
          "command": "resist.lint.changeStage",
          "when": "view == resist.panel",
          "group": "4_filter@3"
        },
        {
          "command": "resist.lint.listRules",
          "when": "view == resist.panel",
          "group": "5_info@1"
        },
        {
          "command": "resist.lint.showTiming",
          "when": "view == resist.panel",
          "group": "5_info@2"
        },
        {
          "command": "resist.lint.showOutput",
          "when": "view == resist.panel",
          "group": "6_output@1"
        },
        {
          "command": "resist.lint.clearOutput",
          "when": "view == resist.panel",
          "group": "6_output@2"
        }
      ],
      "view/item/context": [
        {
          "command": "resist.lint.file",
          "when": "viewItem == resist.fileDiagnostic"
        },
        {
          "command": "resist.lint.fix",
          "when": "viewItem == resist.fileDiagnostic"
        },
        {
          "command": "resist.lint.workspace",
          "when": "viewItem == resist.section"
        },
        {
          "command": "resist.lint.clear",
          "when": "viewItem == resist.section"
        },
        {
          "command": "resist.lint.restart",
          "when": "viewItem == resist.toolError",
          "group": "inline"
        },
        {
          "command": "resist.lint.fix",
          "when": "viewItem == resist.diagnosticDetail"
        },
        {
          "command": "resist.lint.file",
          "when": "viewItem == resist.diagnosticDetail"
        },
        {
          "command": "resist.lint.listRules",
          "when": "viewItem == resist.diagnosticDetail"
        }
      ]
    },
    "configuration": {
      "title": "Resist Tooling",
      "properties": {
        "resist.lint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Controls whether the Resist linter is active. When disabled, no diagnostics are produced and no CLI processes are spawned."
        },
        "resist.lint.onSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically lint files each time they are saved."
        },
        "resist.lint.onType": {
          "type": "boolean",
          "default": true,
          "description": "Lint files as you type, after a configurable debounce delay."
        },
        "resist.lint.onOpen": {
          "type": "boolean",
          "default": true,
          "description": "Lint files immediately when they are opened in the editor."
        },
        "resist.lint.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "description": "Delay in milliseconds before lint-on-type triggers after the last keystroke. Lower values give faster feedback but increase CPU usage."
        },
        "resist.lint.maxProblems": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum number of diagnostics reported per file. Limits output in files with many issues."
        },
        "resist.lint.stage": {
          "type": "string",
          "default": "lint",
          "enum": [
            "lint",
            "check",
            "pre-commit",
            "build",
            "ci",
            "test"
          ],
          "description": "Stage gate that determines which rules are active. Each rule declares which stages it runs in."
        },
        "resist.lint.categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Filter rules by category. Only rules matching these categories will run. Leave empty to run all categories."
        },
        "resist.lint.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional CLI arguments passed directly to the linter process. Use for flags not exposed as dedicated settings."
        },
        "resist.lint.cache": {
          "type": "boolean",
          "default": true,
          "description": "Cache file hashes to skip unchanged files on subsequent lint runs. Disable to force a full re-check every time."
        },
        "resist.lint.quiet": {
          "type": "boolean",
          "default": false,
          "description": "Suppress warnings and only report errors. Useful for focusing on critical issues."
        },
        "resist.lint.debug": {
          "type": "boolean",
          "default": false,
          "description": "Log detailed debug information (timing, cache stats, rule counts) to the Resist output channel."
        },
        "resist.lint.severityOverride": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "error",
            "warn",
            "off"
          ],
          "description": "Override the severity of all rules globally. Leave empty to use each rule's configured severity."
        },
        "resist.lint.rule": {
          "type": "string",
          "default": "",
          "description": "Run only a single rule by its ID (e.g., 'naming/no-default-export'). Useful for debugging individual rules. Leave empty to run all rules."
        },
        "resist.lint.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns for files and directories to exclude from linting (e.g., 'dist/**', '*.generated.ts')."
        },
        "resist.lint.jobs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 32,
          "description": "Number of parallel worker threads for linting. Set to 0 to auto-detect based on available CPU cores."
        },
        "resist.lint.tools": {
          "type": "boolean",
          "default": true,
          "description": "Enable external tool integration (e.g., dependency-cruiser, knip, typos). External tools must be installed separately."
        },
        "resist.lint.locale": {
          "type": "string",
          "default": "",
          "description": "Locale code for diagnostic messages (e.g., 'en'). Leave empty to use the system default locale."
        },
        "resist.lint.bail": {
          "type": "boolean",
          "default": false,
          "description": "Stop the linter after the first error is found. Useful for large workspaces where you want fast failure."
        },
        "resist.lint.fixOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply all auto-fixable lint errors when a file is saved."
        },
        "resist.lint.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show inline code lenses above lines with lint diagnostics displaying rule ID and issue count."
        },
        "resist.lint.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Register the linter as a formatting provider so lint fixes run as part of format-on-save."
        },
        "resist.lint.showTiming": {
          "type": "boolean",
          "default": false,
          "description": "Show per-rule performance timing breakdown in the output channel."
        },
        "resist.lint.staleDiagnosticTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 10000,
          "maximum": 3600000,
          "description": "Time in milliseconds after which diagnostics for idle files are automatically cleared. Set to 300000 (5 min) by default."
        }
      }
    }
  },
  "scripts": {
    "build": "npx tsx scripts/generate-manifest.ts --fix && tsgo -p ./",
    "watch": "tsgo -w -p ./",
    "qa:test": "pnpm -w exec vitest run --project config-tooling-vscode",
    "qa:test:coverage": "pnpm -w exec vitest run --project config-tooling-vscode --coverage --coverage.thresholds.statements=45 --coverage.thresholds.branches=30 --coverage.thresholds.functions=50 --coverage.thresholds.lines=45",
    "clean": "rm -rf dist",
    "build:package": "vsce package --no-dependencies",
    "dev:local": "pnpm build && pnpm build:package && code --install-extension $(ls -t *.vsix | head -1)",
    "qa:benchmark": "pnpm -w exec vitest bench --project config-tooling-vscode",
    "vscode:prepublish": "pnpm build"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.0",
    "vitest": "*"
  }
}
