{
  "name": "@/lint",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "bin": {
    "resist-lint": "./src/cli.ts"
  },
  "scripts": {
    "clean": "rm -rf dist coverage .turbo",
    "qa:test": "pnpm -w exec vitest run --project lint",
    "qa:test:coverage": "pnpm -w exec vitest run --project lint --coverage",
    "qa:benchmark": "pnpm -w exec vitest bench --project lint"
  },
  "dependencies": {
    "oxc-parser": "^0.72.3"
  }
}
