{{syncHeader "#" "https://infisical.com/docs/self-hosting/deployment-options/docker-compose"}}

services:
  infisical:
    container_name: infisical
    image: infisical/infisical:v{{ tooling.infisical.serverVersion }}
    restart: unless-stopped
    ports:
      - "8080:8080"
    env_file: .env.infisical
    environment:
      - NODE_ENV=production
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_started
    networks:
      - infisical

  db:
    container_name: infisical-db
    image: postgres:14-alpine
    restart: unless-stopped
    env_file: .env.infisical
    volumes:
      - infisical_pg_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U infisical"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - infisical

  redis:
    container_name: infisical-redis
    image: redis:7-alpine
    restart: unless-stopped
    volumes:
      - infisical_redis_data:/data
    networks:
      - infisical

volumes:
  infisical_pg_data:
  infisical_redis_data:

networks:
  infisical:
    driver: bridge
