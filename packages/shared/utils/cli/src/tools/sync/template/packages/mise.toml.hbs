{{syncHeader "#" "https://mise.jdx.dev/configuration.html"}}

min_version = "{{ versions.systemTools.mise }}"

[settings]
# Ignore legacy version files (.nvmrc, .node-version, .ruby-version) for
# Node — let the [tools] block in this file be the single source of truth.
# Exception: ui/ios/App/.ruby-version stays read so Bundler picks it up.
# Read .nvmrc for Node version (generated by sync from versions.node)
idiomatic_version_file_enable_tools = ["node", "ruby"]

# Enable Corepack for pnpm (managed via packageManager field in package.json)
node.corepack = true

# Faster install path — uses precompiled binaries when available
experimental = true

# Don't auto-install missing tool versions on `mise activate` — explicit
# `mise install` is safer for collaborators who might not realize a
# multi-GB Ruby compile is queued.
auto_install = false

# Lockfile — once mise.lock exists, mise refuses to install versions
# that don't match (signed SHAs). First `mise install` creates it.
lockfile = true

# Don't trust child .mise.toml files in subdirectories unless explicitly
# allow-listed (`mise trust`). Defence against malicious subprojects.
paranoid = false

[env]
# Workspace-scoped tool installations — all binaries live inside the repo
MISE_INSTALLS_DIR = "{{curly "config_root"}}/.mise/installs"

# mise manages package manager not corepack
COREPACK_ENABLE_STRICT = "0"

[tools]
# System tools from versions.systemTools (mise itself excluded — managed by bootstrap script)
{{#each versions.systemTools}}
{{#unless (eq @key "mise")}}
{{miseBackend @key}} = "{{this}}"
{{/unless}}
{{/each}}
