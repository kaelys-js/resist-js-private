{{syncHeader "#" "https://docs.npmjs.com/cli/v10/configuring-npm/npmrc"}}

# ============================================
# Package Initialization
# ============================================
init-author-name = "{{ business.company }}"
init-author-email = "{{ business.emails.npm }}"
init-author-url = "{{ business.domains.marketing }}"
init-license = "{{ business.license }}"
init-version = "0.0.0"

# ============================================
# Publishing
# ============================================
publish-branch = "{{ git.npm_publish_branch }}"
access = public
git-tag-version = true
commit-hooks = true
tag-version-prefix = "v"

# ============================================
# Version Resolution
# ============================================
save-prefix = ""
save-exact = true

# ============================================
# Engine Enforcement
# ============================================
engine-strict = true

# ============================================
# Performance & Caching
# ============================================
prefer-offline = true
fetch-retries = 3
fetch-retry-mintimeout = 10000
fetch-retry-maxtimeout = 60000

# ============================================
# Security
# ============================================
audit = true
audit-level = moderate

{{#ifPm "pnpm"}}
# ============================================
# pnpm: Peer Dependencies
# ============================================
auto-install-peers = true
strict-peer-dependencies = false

# ============================================
# pnpm: Workspace
# ============================================
link-workspace-packages = true
save-workspace-protocol = rolling
dedupe-direct-deps = true
verify-deps-before-run = install

# ============================================
# pnpm: Node.js Version
# ============================================
use-node-version = {{ versions.node }}

# ============================================
# pnpm: Network
# ============================================
network-concurrency = 16

# ============================================
# pnpm: Hoisting
# ============================================
shamefully-hoist = false
public-hoist-pattern[] = *types*
public-hoist-pattern[] = *svelte*
public-hoist-pattern[] = *vite*
public-hoist-pattern[] = *vitest*
public-hoist-pattern[] = *playwright*
public-hoist-pattern[] = *oxlint*
public-hoist-pattern[] = *biome*
public-hoist-pattern[] = *prettier*
public-hoist-pattern[] = *valibot*
public-hoist-pattern[] = *capacitor*
public-hoist-pattern[] = *cloudflare*

# ============================================
# pnpm: Node Options (alias loader bootstrap)
# ============================================
node-options = "--import data:text/javascript,const{pathToFileURL:f}=await%20import('node:url');const{join:j,dirname:d}=await%20import('node:path');const{existsSync:e}=await%20import('node:fs');let%20p=process.cwd();while(!e(j(p,'pnpm-workspace.yaml'))%26%26d(p)!==p)p=d(p);if(e(j(p,'pnpm-workspace.yaml')))await%20import(f(j(p,'packages','shared','config','tooling','node','src','register-aliases.mjs')).href)"
{{/ifPm}}

# TODO: Sort all the below into proper sections and add commenting and also gate these if they only work in pnpm and validate all of these properties exist, are correct and not already defaults
prefer-frozen-lockfile=true
loglevel=warnings
node-linker=isolated
package-import-method=hardlink
dedupe-peer-dependents=true
side-effects-cache=true
side-ffects-cache-readonly=false
package-manager-strict=true
confirm-modules-purge=false
manage-package-manager-versions=true
strict-ssl=true
registry=https://registry.npmjs.org
verify-store-integrity=true