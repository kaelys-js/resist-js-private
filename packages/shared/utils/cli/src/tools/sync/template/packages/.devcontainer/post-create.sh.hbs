set -euo pipefail

echo "==> Installing system tools from mise.toml..."
# mise.toml is generated by sync and pins all system tool versions
# (caddy, mkcert, cloudflared, infisical, terraform, etc.)
if command -v mise &>/dev/null; then
	mise install
	mise reshim
elif [ -x "./bin/mise" ]; then
	./bin/mise install
	./bin/mise reshim
else
	echo "WARNING: mise not found, skipping system tool installation"
fi

echo "==> Installing project dependencies..."
# Uses the frozen lockfile to ensure reproducible installs
{{ pm.installFrozen }}

echo "==> Checking onboarding status..."
# The .onboarded marker file is created by the onboard command.
# If it doesn't exist, this is a first-time setup.
if [ ! -f "{{ tooling.paths.markerDir }}/.onboarded" ]; then
	echo "    First-time setup detected, running onboarding..."
	{{ pm.run }} onboard
else
	echo "    Already onboarded, skipping."
fi

echo "==> Dev container setup complete!"
