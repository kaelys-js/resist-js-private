{
	"$schema": "{{schemaPath 'tooling/all-contributorsrc'}}",
	"projectName": "{{ repo.name }}",
	"projectOwner": "{{ repo.owner }}",
	"repoType": "{{ git.provider }}",
	"repoHost": "{{ git.providerUrl }}",
	"files": ["CONTRIBUTORS.md"],
	"imageSize": 80,
	"commit": false,
	"commitConvention": "angular",
	"commitType": "docs",
	"skipCi": true,
	"linkToUsage": false,
	"contributorsPerLine": 8,
	"contributorsSortAlphabetically": true,
	"contributors": []
}
