// TODO: Sort keys
{
  "$schema": "{{schemaPath 'tooling/prettier'}}",
  "useTabs": false,
  "tabWidth": {{ format.global.indent_size }},
  "printWidth": {{ format.global.line_length }},
  "endOfLine": "lf",
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "svelteSortOrder": "options-scripts-markup-styles",
  "svelteAllowShorthand": true
  "plugins": ["prettier-plugin-svelte"],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    }
  ]
}
