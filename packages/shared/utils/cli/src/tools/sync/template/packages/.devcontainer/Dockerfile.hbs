{{! https://docs.docker.com/reference/dockerfile/ }}

# Build args — injected from devcontainer.json build.args
ARG NODE_VERSION={{ versions.node }}
ARG PM_NAME={{ pm.name }}
ARG PM_VERSION={{ versions.packageManager }}

# Base image — minimal Ubuntu with devcontainer infrastructure
FROM {{ tooling.devContainer.baseImage }}

# Re-declare ARGs after FROM (Docker scoping rule — ARGs before FROM
# are consumed by FROM but not available in subsequent instructions)
ARG NODE_VERSION
ARG PM_NAME
ARG PM_VERSION

# System dependencies:
# - curl: downloading mise, tools
# - git: version control (also installed by feature, but needed during build)
# - ca-certificates: HTTPS connections
# - build-essential: native Node modules (node-gyp, C++ addons)
# - User-specified packages from resist.config.ts tooling.devContainer.aptPackages
RUN apt-get update && apt-get install -y --no-install-recommends \
	curl \
	git \
	ca-certificates \
	build-essential \
{{#each tooling.devContainer.aptPackages}}
	{{ this }} \
{{/each}}
	&& rm -rf /var/lib/apt/lists/*

# Install mise — the universal version manager.
# mise manages Node, system tools (caddy, mkcert, terraform, cloudflared, etc.)
# all from a single mise.toml config file.
# Installed to /usr/local/bin so it's available for all users.
ENV MISE_INSTALL_PATH="/usr/local/bin/mise"
RUN curl -fsSL https://mise.jdx.dev/install.sh | bash

# Install Node.js via mise (matches the exact version in resist.config.ts).
# mise use -g makes this the global default Node version.
RUN mise install node@${NODE_VERSION} \
	&& mise use -g node@${NODE_VERSION}

# Enable corepack (ships with Node) and install the exact package manager version.
# corepack transparently manages pnpm/yarn versions per-project.
RUN corepack enable \
	&& corepack prepare ${PM_NAME}@${PM_VERSION} --activate

# Tell mise to look for the repo's config when the workspace is mounted.
# The actual mise.toml is generated by sync and lives at the workspace root.
ENV MISE_CONFIG_FILE="/workspaces/.mise.toml"
