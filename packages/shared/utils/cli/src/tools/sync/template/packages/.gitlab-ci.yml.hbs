# YAML anchors for package manager setup (DRY)
.pm-setup: &pm-setup
  before_script:
{{#ifPm "pnpm"}}
    - corepack enable
    - corepack prepare pnpm@{{ pm.version }} --activate
    - pnpm install --frozen-lockfile
{{/ifPm}}
{{#ifPm "npm"}}
    - npm ci
{{/ifPm}}
{{#ifPm "yarn"}}
    - corepack enable
    - yarn install --immutable
{{/ifPm}}
{{#ifPm "bun"}}
    - curl -fsSL https://bun.sh/install | bash
    - export PATH="$HOME/.bun/bin:$PATH"
    - bun install --frozen-lockfile
{{/ifPm}}

image: node:{{ versions.node }}

variables:
  TURBO_TOKEN: $TURBO_TOKEN
  TURBO_TEAM: $TURBO_TEAM

stages:
  - test
  - deploy-staging
  - e2e
  - deploy-prod

# =============================================================================
# Test Stage
# =============================================================================

lint-and-test:
  stage: test
  <<: *pm-setup
  script:
    - {{ pm.run }} qa:checks
    - {{ pm.run }} qa:format:check
    - {{ pm.run }} qa:test
  rules:
    - if: $CI_MERGE_REQUEST_IID
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH

# =============================================================================
# Deploy Staging
# =============================================================================

deploy-staging:
  stage: deploy-staging
  <<: *pm-setup
  script:
    - {{ pm.run }} deploy:staging
  variables:
    CLOUDFLARE_API_TOKEN: $CLOUDFLARE_API_TOKEN
    CLOUDFLARE_ACCOUNT_ID: $CLOUDFLARE_ACCOUNT_ID
  environment:
    name: staging
  needs:
    - lint-and-test
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH

# =============================================================================
# E2E Staging
# =============================================================================

e2e-staging:
  stage: e2e
  <<: *pm-setup
  script:
    - {{ pm.dlx }} playwright install --with-deps
    - {{ pm.run }} qa:test:e2e
  needs:
    - deploy-staging
  rules:
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH

# =============================================================================
# Deploy Production
# =============================================================================

deploy-prod:
  stage: deploy-prod
  <<: *pm-setup
  script:
    - {{ pm.run }} deploy:prod
  variables:
    CLOUDFLARE_API_TOKEN: $CLOUDFLARE_API_TOKEN
    CLOUDFLARE_ACCOUNT_ID: $CLOUDFLARE_ACCOUNT_ID
  environment:
    name: production
  needs:
    - lint-and-test
  rules:
    - if: $CI_COMMIT_TAG =~ /^prod-/
  when: manual
