# ============================================
# Config Files
# ============================================
.gitattributes text eol=lf
.gitignore text eol=lf
.gitmodules text eol=lf
.editorconfig text eol=lf diff=ini
.npmrc text eol=lf diff=ini
.nvmrc text eol=lf
.prettierrc text eol=lf
.prettierignore text eol=lf
.eslintrc text eol=lf
.eslintignore text eol=lf
.dockerignore text eol=lf
.browserslistrc text eol=lf
Makefile text eol=lf
Procfile text eol=lf

# ============================================
# Capacitor — iOS
# ============================================
*.pbxproj text eol=lf -diff merge=union
*.plist text eol=lf
*.storyboard binary
*.xib binary
*.strings text eol=lf
*.xcworkspacedata text -merge
*.xcscheme        text -merge
*.xcsettings      text -merge
*.plist           text -merge
*.entitlements    text -merge

# ============================================
# TypeScript Definitions
# ============================================
*.d.ts text eol=lf linguist-generated=false

# ============================================
# Lock Files (preserve exactly, no diff)
# ============================================
package-lock.json text eol=lf -diff linguist-generated=true
yarn.lock text eol=lf -diff linguist-generated=true
pnpm-lock.yaml text eol=lf -diff linguist-generated=true
bun.lockb binary linguist-generated=true
composer.lock text eol=lf -diff linguist-generated=true
Gemfile.lock text eol=lf -diff linguist-generated=true
Cargo.lock text eol=lf -diff linguist-generated=true
go.sum text eol=lf -diff linguist-generated=true
poetry.lock text eol=lf -diff linguist-generated=true
shrinkwrap.yaml text eol=lf -diff linguist-generated=true
Package.resolved text eol=lf -diff linguist-generated=true

