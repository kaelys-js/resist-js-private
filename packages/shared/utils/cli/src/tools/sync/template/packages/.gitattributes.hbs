{{syncHeader "#" "https://git-scm.com/docs/gitattributes"}}

# Auto-detect text files and normalize line endings
* text=auto eol=lf

# ============================================
# Source Code — JavaScript/TypeScript
# ============================================
*.ts text eol=lf
*.tsx text eol=lf
*.mts text eol=lf
*.cts text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# ============================================
# Source Code — Web Frameworks
# ============================================
*.svelte text eol=lf diff=html
*.vue text eol=lf diff=html
*.astro text eol=lf diff=html

# ============================================
# Source Code — Styles
# ============================================
*.css text eol=lf diff=css
*.scss text eol=lf diff=css
*.sass text eol=lf diff=css
*.less text eol=lf diff=css
*.postcss text eol=lf diff=css

