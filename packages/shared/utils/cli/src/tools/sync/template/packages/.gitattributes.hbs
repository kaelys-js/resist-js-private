# ============================================
# Windows Scripts (CRLF required)
# ============================================
*.bat text eol=crlf
*.BAT text eol=crlf
*.cmd text eol=crlf
*.CMD text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
