{
	"$schema": "https://json.schemastore.org/vs-code-settings",

	"editor.formatOnSave": false,
	"editor.formatOnPaste": false,
	"editor.formatOnType": false,

	"resistFormatter.enable": true,
	"resistFormatter.formatOnSave": true,
	"resistFormatter.formatOnType": false,
	"resistFormatter.formatOnPaste": false,

	"typescript.tsdk": "node_modules/typescript/lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,
	"typescript.tsserver.log": "off",
	"typescript.tsserver.maxTsServerMemory": 4096,
	"typescript.tsserver.useSyntaxServer": "auto",
	"typescript.preferences.importModuleSpecifier": "non-relative",
	"typescript.preferences.includePackageJsonAutoImports": "auto",
	"typescript.preferences.preferTypeOnlyAutoImports": true,
	"typescript.suggest.autoImports": true,
	"typescript.suggest.includeCompletionsForModuleExports": false,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"typescript.inlayHints.parameterNames.enabled": "literals",
	"javascript.suggest.autoImports": true,
	"javascript.preferences.importModuleSpecifier": "non-relative",
	"javascript.updateImportsOnFileMove.enabled": "always",

	"files.autoSave": "off",
	"files.eol": "\n",
	"files.encoding": "utf8",
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"files.associations": {
	".env.*": "dotenv",
	".dev.vars": "dotenv",
	".dev.vars.*": "dotenv",
	".editorconfig": "editorconfig",
	".npmrc": "properties",
	".nvmrc": "plaintext",
	".gitignore": "ignore",
	".dockerignore": "ignore",
	".prettierignore": "ignore",
	".eslintignore": "ignore",
	".helmignore": "ignore",
	".gitattributes": "properties",
	".all-contributorsrc": "json",
	".prettierrc": "json",
	".eslintrc": "json",
	".rubocop.yml": "yaml",
	"*.jsonc": "jsonc",
	"*.json5": "json5",
	"biome.json": "jsonc",
	"biome.jsonc": "jsonc",
	"turbo.json": "jsonc",
	"vercel.json": "json",
	"deno.json": "jsonc",
	"deno.jsonc": "jsonc",
	"Dockerfile*": "dockerfile",
	"dockerfile*": "dockerfile",
	"Makefile": "makefile",
	"makefile": "makefile",
	"GNUmakefile": "makefile",
	"gnumakefile": "makefile",
	"CMakeLists.txt": "cmake",
	"Gemfile": "ruby",
	"Rakefile": "ruby",
	"Podfile": "ruby",
	"Fastfile": "ruby",
	"Appfile": "ruby",
	"Matchfile": "ruby",
	"Vagrantfile": "ruby",
	"justfile": "just",
	"Justfile": "just",
	"*.blade.php": "blade",
	"chart.yaml": "yaml",
	"chart.yml": "yaml",
	"values.yaml": "yaml",
	"values.yml": "yaml",
	"CODEOWNERS": "codeowners",
	"funding.yml": "yaml",
	"dependabot.yml": "yaml",
	"dependabot.yaml": "yaml",
	"wrangler.toml": "toml",
	"netlify.toml": "toml",
	"cargo.toml": "toml",
	"Cargo.toml": "toml",
	"pyproject.toml": "toml",
	"composer.json": "json",
	"*.pyi": "python",
	"*.pyx": "python",
	"*.pxd": "python",
	"go.mod": "go.mod",
	"*.hrl": "erlang",
	"*.lhs": "haskell",
	"*.mli": "ocaml",
	"*.re": "reason",
	"*.rei": "reason",
	"*.pkr.hcl": "hcl",
	"*.nomad": "hcl",
	"*.sentinel": "hcl",
	"*.libsonnet": "jsonnet",
	"*.bzl": "starlark",
	"*.bazel": "starlark",
	"*.star": "starlark",
	"*.mk": "makefile",
	"*.ninja": "ninja",
	"*.bib": "bibtex",
	"*.wat": "wat",
	"*.wast": "wat",
	"*.vy": "vyper",
	"*.move": "move",
	"*.cr": "crystal",
	"*.v": "v",
	"*.d": "d",
	"*.jl": "julia",
	"*.thrift": "thrift",
	"*.dhall": "dhall",
	"*.cue": "cue",
	"*.adoc": "asciidoc",
	"*.rst": "restructuredtext",
	"*.hbs": "handlebars",
	"*.handlebars": "handlebars",
	"*.fish": "fish"
	},
	"files.exclude": {
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/*.tsbuildinfo": true,
		"**/*.pyc": true,
		"**/{{ pm.lockfile }}": true,
		"**/.pnpm-store": true,
		"**/.npm": true,
		"**/.yarn": true,
		"**/.vite": true,
		"**/.astro": true,
		"**/.next": true,
		"**/.nuxt": true,
		"**/.output": true,
		"**/.vercel": true,
		"**/.netlify": true,
		"**/*.aux": true,
		"**/*.log": true,
		"**/*.toc": true,
		"**/*.lof": true,
		"**/*.lot": true,
		"**/*.fls": true,
		"**/*.fdb_latexmk": true,
		"**/*.synctex.gz": true,
{{#vscodeExclude}}
{{> exclude-dirs-extended}}
{{/vscodeExclude}}
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/{{ pm.lockfile }}": true,
		"**/.pnpm-store/**": true,
		"**/.npm/**": true,
		"**/.yarn/**": true,
		"**/.vite/**": true,
		"**/.astro/**": true,
		"**/.next/**": true,
		"**/.nuxt/**": true,
		"**/.output/**": true,
		"**/.vercel/**": true,
		"**/.netlify/**": true,
{{#vscodeExclude suffix="/**"}}
{{> exclude-dirs-extended}}
{{/vscodeExclude}}
	},
	"search.exclude": {
		"**/{{ pm.lockfile }}": true,
		"**/.pnpm-store": true,
		"**/.npm": true,
		"**/.yarn": true,
		"**/.vite": true,
		"**/.astro": true,
		"**/.next": true,
		"**/.nuxt": true,
		"**/.output": true,
		"**/.vercel": true,
		"**/.netlify": true,
{{#vscodeExclude}}
{{> exclude-dirs-extended}}
{{/vscodeExclude}},
		"**/*.min.js": true,
		"**/*.min.css": true,
		"**/*.map": true,
		"**/*.chunk.js": true,
		"**/*.bundle.js": true,
		"**/*.aux": true,
		"**/*.log": true,
		"**/*.toc": true,
		"**/*.synctex.gz": true
	},
	"search.useGlobalIgnoreFiles": true,
	"search.followSymlinks": false,

	"editor.tabSize": {{ format.global.tab_width }},
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"editor.bracketPairColorization.enabled": true,
	"editor.guides.bracketPairs": "active",
	"editor.codeLens": true,
	"editor.fontLigatures": true,
	"editor.inlineSuggest.enabled": true,
	"editor.linkedEditing": true,
	"editor.minimap.enabled": false,
	"editor.renderWhitespace": "trailing",
	"editor.semanticHighlighting.enabled": true,
	"editor.smoothScrolling": true,
	"editor.stickyScroll.enabled": true,

	"workbench.editor.enablePreview": false,
	"workbench.editor.revealIfOpen": true,
	"workbench.startupEditor": "none",
	"window.title": "${dirty}${activeEditorShort}${separator}${rootName}",

	"git.autofetch": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.pruneOnFetch": true,

	"terminal.integrated.scrollback": 10000,

	"testing.automaticallyOpenPeekView": "never",

	"svelte.enable-ts-plugin": true,

	"telemetry.telemetryLevel": "off",

	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		"package.json": "{{ pm.lockfile }}, .npmrc, .nvmrc, .node-version",
		"tsconfig.json": "tsconfig.*.json, jsconfig.json",
		"svelte.config.js": "vite.config.*, vitest.config.*, postcss.config.*, tailwind.config.*",
		"biome.json": "biome.jsonc, oxlint.json, .eslintrc*, .prettierrc*, .prettierignore, .eslintignore",
		".gitignore": ".gitattributes, .editorconfig, .mailmap",
		"README.md": "LICENSE, CHANGELOG.md, CONTRIBUTING.md, CODE_OF_CONDUCT.md, SECURITY.md, CODEOWNERS",
		"Dockerfile": "Dockerfile.*, docker-compose*.yml, docker-compose*.yaml, .dockerignore",
		"Makefile": "GNUmakefile, *.mk",
		"Cargo.toml": "Cargo.lock, rust-toolchain.toml",
		"pyproject.toml": "setup.py, setup.cfg, requirements*.txt, poetry.lock, Pipfile, Pipfile.lock, .python-version, ruff.toml",
		"Gemfile": "Gemfile.lock, .ruby-version, .rubocop.yml",
		"composer.json": "composer.lock, phpunit.xml",
		"go.mod": "go.sum, .golangci.yml",
		"deno.json": "deno.jsonc, deno.lock, import_map.json",
		"turbo.json": "turbo.jsonc",
		"wrangler.toml": ".dev.vars",
		".env": ".env.*",
		"lefthook.yml": ".husky",
		"mix.exs": "mix.lock, .formatter.exs, .credo.exs",
		"pubspec.yaml": "pubspec.lock, analysis_options.yaml",
		"flake.nix": "flake.lock",
		"BUILD.bazel": "WORKSPACE, WORKSPACE.bazel, .bazelrc, .bazelversion",
		"hardhat.config.js": "foundry.toml, remappings.txt",
		"capacitor.config.ts": "ionic.config.json"
	}{{#if vscodeJsonSchemas}},

	"json.schemas": {{jsonShifted vscodeJsonSchemas outer="\t"}}{{/if}}
}
