{
	"name": "@finances/editor",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_OPTIONS='--enable-source-maps' vite dev",
		"prebuild": "bash scripts/generate-icons.sh",
		"build": "vite build",
		"preview": "vite preview",
		"clean": "rm -rf .svelte-kit dist",
		"qa:test": "cd ../../../.. && vitest run --project finances-editor",
		"qa:test:unit": "cd ../../../.. && vitest run --project finances-editor",
		"qa:test:coverage": "cd ../../../.. && vitest run --project finances-editor --coverage",
		"qa:benchmark": "cd ../../../.. && vitest bench --project finances-editor",
		"qa:test:e2e": "playwright test",
		"qa:type-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"state_referenced_locally:ignore\"",
		"generate-icons": "bash scripts/generate-icons.sh"
	},
	"dependencies": {
		"@/schemas/common": "workspace:*",
		"@/schemas/result": "workspace:*",
		"@/ui": "workspace:*",
		"@/utils/result": "workspace:*",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.2",
		"bits-ui": "^2.16.2",
		"clsx": "^2.1.1",
		"d3-array": "^3.0.0",
		"d3-scale": "^4.0.0",
		"d3-shape": "^3.0.0",
		"layerchart": "^1.0.13",
		"mode-watcher": "^1.1.0",
		"perfume.js": "^9.4.0",
		"svelte": "^5.53.5",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@/config/test": "workspace:*",
		"@cloudflare/workers-types": "^4.20260305.1",
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"paneforge": "^1.0.2",
		"svelte-check": "^4.4.3",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"wrangler": "^4.71.0"
	}
}
