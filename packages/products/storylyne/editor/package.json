{
  "name": "@storylyne/editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync",
    "svelte-kit:sync": "svelte-kit sync",
    "dev": "NODE_OPTIONS='--enable-source-maps' vite dev",
    "prebuild": "bash ../../../../packages/shared/utils/cli/src/tools/generate-icons/generate-icons.sh .",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf .svelte-kit dist",
    "qa:test": "pnpm -w exec vitest run --project storylyne-editor --project storylyne-editor-server",
    "qa:test:unit": "pnpm -w exec vitest run --project storylyne-editor --project storylyne-editor-server",
    "qa:test:coverage": "pnpm -w exec vitest run --project storylyne-editor --project storylyne-editor-server --coverage",
    "qa:benchmark": "pnpm -w exec vitest bench --project storylyne-editor",
    "qa:test:e2e": "playwright test",
    "generate-icons": "bash ../../../../packages/shared/utils/cli/src/tools/generate-icons/generate-icons.sh ."
  },
  "dependencies": {
