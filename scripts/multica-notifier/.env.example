# multica-notifier configuration
# Copy this file to .env and fill in real values. .env is gitignored.

# Required: Personal access token from Multica → Settings → API Tokens
MULTICA_API_TOKEN=mul_PASTE_YOUR_TOKEN_HERE

# Required if NTFY_TOPIC unset → script-level error
# Pick an unguessable topic name; the topic IS the access control on ntfy.sh
NTFY_TOPIC=multica-yourname-CHANGEME

# Optional: ntfy.sh server (use https://ntfy.sh public, or your self-hosted instance)
NTFY_BASE=https://ntfy.sh

# Optional: enable native macOS notifications via osascript
MACOS_NOTIFY=true

# Optional: API base + workspace slug (defaults are localhost self-host + resist-js)
MULTICA_API_BASE=http://localhost:8080
MULTICA_WORKSPACE_SLUG=resist-js
MULTICA_APP_BASE=http://localhost:3000

# Optional: poll interval in seconds (lower = faster notifications, more CPU/network)
POLL_INTERVAL=15

# Optional: where the local Multica daemon writes its log
DAEMON_LOG=/Users/home/.multica/daemon.log
